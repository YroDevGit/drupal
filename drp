/* $filename theme styles */

body{
  margin:0;
  font-family:Arial, Helvetica, sans-serif;
}

.container{
  max-width:1200px;
  margin:auto;
}

.site-header{
  background:#222;
  color:#fff;
  padding:20px;
}

.site-footer{
  background:#111;
  color:#fff;
  padding:20px;
}
EOT;

    file_put_contents($tpath . "/css/style.css", $content);
  }


  /* JS */

  if (! file_exists($tpath . "/js/script.js")) {
    $content = <<<EOT
// $filename theme javascript
console.log("$filename theme loaded");
EOT;

    file_put_contents($tpath . "/js/script.js", $content);
  }

  echo "Theme '$filename' created successfully.";
}
