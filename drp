      public static function ajaxCallback(array \$form, FormStateInterface \$form_state)
      {
        \$itemKey = "";
        \$complete_form = \$form_state->getCompleteForm();

        if (isset(\$complete_form[\$itemKey])) {
          return \$complete_form[\$itemKey];
