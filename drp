    .node-page-layout-builder-form .form-actions.sticky {
      position: sticky;
      top: 0;
      background: #fff;
      padding: 10px;
      border-bottom: 1px solid #ccc;
      z-index: 999;
    }

    /* Optional: style vertical tabs */
    .node-page-layout-builder-form .vertical-tabs__menu-item {
      background: #f5f5f5;
      border: 1px solid #ccc;
      border-radius: 3px 3px 0 0;
      margin-right: 2px;
      padding: 4px 8px;
      cursor: pointer;
    }

    .node-page-layout-builder-form .vertical-tabs__menu-item.is-selected {
      background: #0074bd;
      color: #fff;
    }
    EOT;

    file_put_contents($tpath . "/css/special_".$ss.".css", $content);
  }

  /* JS */

  if (! file_exists($tpath . "/js/script.js")) {
    $content = <<<EOT
// $filename theme javascript
console.log("$filename theme loaded");
EOT;

    file_put_contents($tpath . "/js/script.js", $content);
  }

  echo "✅ Theme '$filename' created successfully.";
}



