        \$data = \$this->data();
        \$ret =  [
          '#theme' => '$filename',
          '#attached' => [
            'library' => [
              '$filename/$filename-styles',
            ],
          ],
        ];
        foreach (\$data as \$key => \$val) {
          \$krg = \$this->configuration[\$key] ?? null;
          if (is_array(\$krg)) {
            foreach (\$krg as \$k => \$v) {
              if(! is_array(\$v)) {\$ret["#" . \$key] = \$krg; continue;}
              \$num = false;
              foreach (\$v as \$kk => \$vv) {
                if (\$vv) \$num = true;
              }
              if (\$num == true) \$ret["#" . \$key][] = \$krg[\$k];
            }
          } else {
            \$ret["#" . \$key] = \$krg;
          }
        }
        return \$ret;
      }
    }

